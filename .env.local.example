# ── Auth ──────────────────────────────────────────────────────────────────────
# Firma los tokens de sesión (cookie brandit_session, HMAC). Obligatorio.
AUTH_SECRET=

# ── Supabase (proyecto Apps Familia) ──────────────────────────────────────────
# El acceso a datos es 100% server-side con service_role (SEC-1: ya no se usa el
# anon key en el browser). SUPABASE_URL cae a NEXT_PUBLIC_SUPABASE_URL si falta.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=

# ── Switch API (Confecciones Boston) ──────────────────────────────────────────
SWITCH_BOSTON_API_URL=
SWITCH_BOSTON_API_USER=
SWITCH_BOSTON_API_PASSWORD=

# ── Crons ─────────────────────────────────────────────────────────────────────
# Bearer para /api/cron/* (switch-sync, sync-recibos, backup, etc.).
CRON_SECRET=

# ── Integraciones ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=          # chat asistente
RESEND_API_KEY=             # emails (guias-summary, etc.)
GOOGLE_CLIENT_ID=           # Google Calendar (leads)
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
